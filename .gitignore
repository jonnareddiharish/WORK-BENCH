# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
apps/**/.env
apps/**/.env.*
!apps/**/.env.example

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
build/

# ── NX cache & workspace data ─────────────────────────────────────────────────
.nx/cache
.nx/workspace-data

# ── TypeScript build info ─────────────────────────────────────────────────────
*.tsbuildinfo

# ── Test coverage & results ───────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Playwright E2E ────────────────────────────────────────────────────────────
test-results/
playwright-report/
playwright/.cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-error.log
logs/

# ── HuggingFace model cache (downloaded at runtime, ~90 MB) ──────────────────
.cache/
**/node_modules/.cache/

# ── IDE & editor files ────────────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Claude Code internal ──────────────────────────────────────────────────────
.claude/worktrees
.claude/settings.local.json

# ── Misc ──────────────────────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/libpeerconnection.log
testem.log
/typings
