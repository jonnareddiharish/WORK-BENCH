# Camunda Engine
CAMUNDA_URI=http://localhost:8080/engine-rest
CAMUNDA_USERNAME=demo
CAMUNDA_PASSWORD=demo

# Optional: unique ID for this worker instance (auto-generated if not set)
CAMUNDA_APP_WORKER_ID=agent-workers-1

# Optional: polling tuning
CAMUNDA_MAX_TASKS=10
CAMUNDA_LOCK_DURATION=5000
CAMUNDA_RETRY_TIMEOUT=2000
CAMUNDA_ASYNC_RESPONSE_TIMEOUT=5000
CAMUNDA_MAX_PARALLEL_EXECUTIONS=10
CAMUNDA_INTERVAL=500
