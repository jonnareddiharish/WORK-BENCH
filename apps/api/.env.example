# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/workbench

# AI API Keys
ANTHROPIC_API_KEY=          # Claude Sonnet — console.anthropic.com
OPENAI_API_KEY=             # GPT-4o Mini — platform.openai.com/api-keys
GOOGLE_API_KEY=             # Gemini 1.5 Flash (free) — aistudio.google.com/apikey
GROQ_API_KEY=               # Llama 3.3 70B (free, no card) — console.groq.com/keys

# Neo4j (optional, enables graph features + semantic search)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Server Configuration
PORT=3000
NODE_ENV=development

# API Configuration
API_PREFIX=/api
