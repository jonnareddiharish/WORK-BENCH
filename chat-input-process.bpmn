    <bpmn:serviceTask id="Activity_start_ai" name="Start AI Suggestions" camunda:type="external" camunda:topic="start-ai-suggestor-topic">
      <bpmn:incoming>Flow_from_join</bpmn:incoming>
      <bpmn:outgoing>Flow_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_02fanxm">
      <bpmn:incoming>Flow_1dsms3r</bpmn:incoming>
      <bpmn:outgoing>Flow_0jpozpz</bpmn:outgoing>
      <bpmn:outgoing>Flow_145h3y3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_join">
      <bpmn:incoming>Flow_0dhra1y</bpmn:incoming>
      <bpmn:incoming>Flow_145h3y3</bpmn:incoming>
      <bpmn:outgoing>Flow_from_join</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:subProcess id="Activity_0l6ndpk" name="Diet Logs">
      <bpmn:incoming>Flow_0jpozpz</bpmn:incoming>
      <bpmn:outgoing>Flow_0dhra1y</bpmn:outgoing>
      <bpmn:startEvent id="Event_12lrvaw">
        <bpmn:outgoing>Flow_sub_to_analyze</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Activity_analyze_diet" name="Analyze Diet Content" camunda:type="external" camunda:topic="topic.health.diet.analyze">
        <bpmn:incoming>Flow_sub_to_analyze</bpmn:incoming>
        <bpmn:outgoing>Flow_sub_to_save</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Activity_0dn9xn9" name="Save Diet Content" camunda:type="external" camunda:topic="topic.health.diet.save">
        <bpmn:incoming>Flow_sub_to_save</bpmn:incoming>
        <bpmn:outgoing>Flow_sub_to_end</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="Event_1dvwp8v">
        <bpmn:incoming>Flow_sub_to_end</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_sub_to_analyze" sourceRef="Event_12lrvaw" targetRef="Activity_analyze_diet" />
      <bpmn:sequenceFlow id="Flow_sub_to_save" sourceRef="Activity_analyze_diet" targetRef="Activity_0dn9xn9" />
      <bpmn:sequenceFlow id="Flow_sub_to_end" sourceRef="Activity_0dn9xn9" targetRef="Event_1dvwp8v" />
    </bpmn:subProcess>
  </bpmn:process>
