  <bpmn:process id="chat-input-processor" name="Chat Input Processor" isExecutable="true" camunda:historyTimeToLive="1">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_1xzvqxb</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="Event_final">
      <bpmn:incoming>Flow_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1xzvqxb" sourceRef="StartEvent_1" targetRef="Activity_0e4z31k" />
    <bpmn:sequenceFlow id="Flow_11ch0us" sourceRef="Activity_0e4z31k" targetRef="Activity_17qmecu" />
    <bpmn:sequenceFlow id="Flow_1dsms3r" sourceRef="Activity_17qmecu" targetRef="Gateway_02fanxm" />
    <bpmn:sequenceFlow id="Flow_0jpozpz" sourceRef="Gateway_02fanxm" targetRef="Activity_0l6ndpk">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${intent == 'DIET_LOGS'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_145h3y3" sourceRef="Gateway_02fanxm" targetRef="Gateway_join">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${intent != 'DIET_LOGS'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0dhra1y" sourceRef="Activity_0l6ndpk" targetRef="Gateway_join" />
    <bpmn:sequenceFlow id="Flow_from_join" sourceRef="Gateway_join" targetRef="Activity_start_ai" />
    <bpmn:sequenceFlow id="Flow_to_end" sourceRef="Activity_start_ai" targetRef="Event_final" />
    <bpmn:serviceTask id="Activity_0e4z31k" name="Get User Details" camunda:type="external" camunda:topic="topic.health.get-user-details">
      <bpmn:incoming>Flow_1xzvqxb</bpmn:incoming>
      <bpmn:outgoing>Flow_11ch0us</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_17qmecu" name="Classify Content" camunda:type="external" camunda:topic="topic.health.classify-content">
      <bpmn:incoming>Flow_11ch0us</bpmn:incoming>
      <bpmn:outgoing>Flow_1dsms3r</bpmn:outgoing>
